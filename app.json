{
  "expo": {
    "name": "Sudoku Farsi",
    "slug": "sudokuFarsi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/SudokuLogo-icon.png",
    "scheme": "sudokufarsi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shopencore.sudokufarsi",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5EDDF",
        "foregroundImage": "./assets/images/SudokuLogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.shopencore.sudokufarsi"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/SudokuLogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAFA"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Vazirmatn-Regular.ttf",
            "./assets/fonts/Vazirmatn-Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}
